{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Apagar",
    "keybind" : "p"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reiniciar",
    "keybind" : "r"
}
{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Bloquear",
    "keybind" : "l"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspender",
    "keybind" : "s"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch exit",
    "text" : "Salir",
    "keybind" : "e"
}
